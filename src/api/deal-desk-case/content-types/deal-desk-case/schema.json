{
  "kind": "collectionType",
  "collectionName": "deal_desk_cases",
  "info": {
    "singularName": "deal-desk-case",
    "pluralName": "deal-desk-cases",
    "displayName": "Real Estate Tax Case"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "caseNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "client": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::client.client",
      "inversedBy": "deal_desk_cases"
    },
    "caseType": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "sale_apartment",
        "purchase_apartment",
        "sale_moshav_estate",
        "purchase_moshav_estate",
        "land",
        "commercial",
        "inheritance",
        "gift",
        "combination",
        "dissolution",
        "rmi_tender"
      ]
    },
    "status": {
      "type": "enumeration",
      "required": true,
      "default": "new",
      "enum": [
        "new",
        "waiting_for_documents",
        "data_review",
        "tax_simulation",
        "legal_review",
        "client_report_sent",
        "tax_authority",
        "completed"
      ]
    },
    "approvalStatus": {
      "type": "enumeration",
      "required": true,
      "default": "draft",
      "enum": [
        "draft",
        "needs_data",
        "ready_for_legal_review",
        "approved_internally",
        "published_to_client",
        "archived"
      ]
    },
    "riskLevel": {
      "type": "enumeration",
      "required": true,
      "default": "medium",
      "enum": [
        "low",
        "medium",
        "high",
        "exceptional"
      ]
    },
    "assignedLawyer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "openedAt": {
      "type": "date"
    },
    "deadline": {
      "type": "date"
    },
    "property": {
      "type": "json"
    },
    "transaction": {
      "type": "json"
    },
    "real_estate_tasks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::real-estate-task.real-estate-task",
      "mappedBy": "case"
    },
    "real_estate_documents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::real-estate-document.real-estate-document",
      "mappedBy": "case"
    },
    "real_estate_tax_scenarios": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::real-estate-tax-scenario.real-estate-tax-scenario",
      "mappedBy": "case"
    },
    "real_estate_notes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::real-estate-note.real-estate-note",
      "mappedBy": "case"
    },
    "real_estate_reports": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::real-estate-report.real-estate-report",
      "mappedBy": "case"
    },
    "real_estate_audit_logs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::real-estate-audit-log.real-estate-audit-log",
      "mappedBy": "case"
    }
  }
}
