{
  "kind": "collectionType",
  "collectionName": "real_estate_documents",
  "info": {
    "singularName": "real-estate-document",
    "pluralName": "real-estate-documents",
    "displayName": "Real Estate Document"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "documentType": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "default": "missing",
      "enum": [
        "missing",
        "uploaded",
        "reviewed",
        "rejected",
        "needs_correction"
      ]
    },
    "clientVisible": {
      "type": "boolean",
      "default": false
    },
    "required": {
      "type": "boolean",
      "default": false
    },
    "dueDate": {
      "type": "date"
    },
    "notes": {
      "type": "text"
    },
    "files": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "case": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::deal-desk-case.deal-desk-case",
      "inversedBy": "real_estate_documents"
    },
    "client": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::client.client"
    }
  }
}
