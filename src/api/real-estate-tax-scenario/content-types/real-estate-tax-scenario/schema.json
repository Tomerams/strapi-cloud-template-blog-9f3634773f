{
  "kind": "collectionType",
  "collectionName": "real_estate_tax_scenarios",
  "info": {
    "singularName": "real-estate-tax-scenario",
    "pluralName": "real-estate-tax-scenarios",
    "displayName": "Real Estate Tax Scenario",
    "description": "Tax simulation or tax position attached to a real-estate case."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "scenarioType": {
      "type": "enumeration",
      "default": "betterment_tax",
      "enum": [
        "betterment_tax",
        "purchase_tax",
        "improvement_levy",
        "moshav_estate_split",
        "rmi_fees",
        "exemption",
        "other"
      ]
    },
    "assumptions": {
      "type": "json"
    },
    "estimatedTax": {
      "type": "decimal"
    },
    "confidence": {
      "type": "enumeration",
      "default": "medium",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "risk": {
      "type": "enumeration",
      "default": "medium",
      "enum": [
        "low",
        "medium",
        "high",
        "exceptional"
      ]
    },
    "status": {
      "type": "enumeration",
      "default": "draft",
      "enum": [
        "draft",
        "review",
        "approved",
        "published",
        "archived"
      ]
    },
    "clientVisible": {
      "type": "boolean",
      "default": false
    },
    "lawyerNotes": {
      "type": "text"
    },
    "calculationJson": {
      "type": "json"
    },
    "case": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::deal-desk-case.deal-desk-case",
      "inversedBy": "real_estate_tax_scenarios"
    }
  }
}
