{
  "kind": "collectionType",
  "collectionName": "real_estate_reports",
  "info": {
    "singularName": "real-estate-report",
    "pluralName": "real-estate-reports",
    "displayName": "Real Estate Report"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "reportType": {
      "type": "enumeration",
      "default": "internal",
      "enum": [
        "internal",
        "client",
        "tax_authority",
        "summary"
      ]
    },
    "status": {
      "type": "enumeration",
      "default": "draft",
      "enum": [
        "draft",
        "published",
        "archived"
      ]
    },
    "clientVisible": {
      "type": "boolean",
      "default": false
    },
    "summary": {
      "type": "richtext"
    },
    "publishedAt": {
      "type": "datetime"
    },
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "files"
      ]
    },
    "case": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::deal-desk-case.deal-desk-case",
      "inversedBy": "real_estate_reports"
    }
  }
}
