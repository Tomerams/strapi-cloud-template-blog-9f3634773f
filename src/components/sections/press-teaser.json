{
  "collectionName": "components_sections_press_teasers",
  "info": {
    "displayName": "PressTeaser",
    "icon": "newspaper"
  },
  "options": {},
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "Press"
    },
    "heading": {
      "type": "string",
      "required": true,
      "default": "פרסומים אחרונים"
    },
    "intro": {
      "type": "text"
    },
    "archiveLinkLabel": {
      "type": "string",
      "default": "לכל הפרסומים"
    },
    "limit": {
      "type": "integer",
      "default": 3,
      "min": 1,
      "max": 12
    },
    "selectionMode": {
      "type": "enumeration",
      "enum": [
        "latest",
        "manual",
        "featured"
      ],
      "default": "latest"
    },
    "layout": {
      "type": "enumeration",
      "enum": [
        "grid",
        "compact",
        "featured"
      ],
      "default": "grid"
    },
    "pressMentions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::press-mention.press-mention"
    }
  },
  "config": {}
}
