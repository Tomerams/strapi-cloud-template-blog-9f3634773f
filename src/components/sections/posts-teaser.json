{
  "collectionName": "components_sections_posts_teasers",
  "info": {
    "displayName": "PostsTeaser",
    "icon": "bulletList"
  },
  "options": {},
  "attributes": {
    "eyebrow": {
      "type": "string"
    },
    "heading": {
      "type": "string",
      "required": true
    },
    "intro": {
      "type": "text"
    },
    "archiveLinkLabel": {
      "type": "string"
    },
    "limit": {
      "type": "integer",
      "default": 3,
      "min": 1,
      "max": 12
    },
    "selectionMode": {
      "type": "enumeration",
      "enum": [
        "latest",
        "manual"
      ],
      "default": "latest"
    },
    "layout": {
      "type": "enumeration",
      "enum": [
        "grid",
        "compact",
        "featured"
      ],
      "default": "grid"
    },
    "posts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::post.post"
    }
  },
  "config": {}
}
